{
  "name": "@taxalens/judge-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12",
    "npm": ">=9"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/verify-review-assets.mjs && tsc -b && vite build",
    "check": "tsc -b --pretty false",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:agent": "vitest run src/agent/agentEvaluation.test.ts",
    "test:deployment": "node --test scripts/static-deployment.test.mjs",
    "test:supabase": "node scripts/verify-supabase-migrations.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify:build": "npm run build && node scripts/verify-static-build.mjs",
    "prepare:deployment": "node scripts/static-deployment.mjs prepare",
    "verify:deployment": "node scripts/static-deployment.mjs verify",
    "build:deployment": "npm run verify:build && npm run prepare:deployment && npm run verify:deployment"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.32.0",
    "@supabase/supabase-js": "2.110.7",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "openai": "6.47.0",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.11",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "fake-indexeddb": "6.2.5",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
