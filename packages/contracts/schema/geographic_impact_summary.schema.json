{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxalens.local/contracts/geographic-impact-summary-v1.0.0.schema.json",
  "title": "TaxaLens geographic impact summary",
  "description": "One deterministic global, continent, country, or admin1 rollup of geographic impact cells.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "geographic_impact_build_id",
    "project_id",
    "run_id",
    "registry_version",
    "accepted_taxon_key",
    "scientific_name",
    "baseline_snapshot_id",
    "flickr_snapshot_id",
    "provider_union_policy_version",
    "verification_projection_version",
    "release_policy_version",
    "country_hierarchy_id",
    "spatial_resolution",
    "scope_level",
    "scope_id",
    "scope_name",
    "parent_scope_id",
    "continent",
    "country_code",
    "country",
    "admin1",
    "baseline_evidence_status",
    "provider_input_row_count",
    "baseline_union_count",
    "baseline_range_inference_eligible_count",
    "baseline_excluded_occurrence_count",
    "gbif_only_count",
    "inaturalist_origin_through_gbif_count",
    "direct_inaturalist_delta_status",
    "direct_inaturalist_delta_count",
    "duplicates_removed_count",
    "unresolved_provider_duplicate_group_count",
    "cell_count",
    "baseline_occupied_cell_count",
    "flickr_candidate_count",
    "flickr_visually_eligible_count",
    "reviewed_positive_count",
    "reviewed_negative_count",
    "uncertain_count",
    "pending_count",
    "media_failure_count",
    "skipped_count",
    "release_ready_count",
    "flickr_occupied_cell_count",
    "baseline_only_cell_count",
    "matched_cell_count",
    "candidate_only_cell_count",
    "reviewed_additional_cell_count",
    "release_ready_additional_cell_count",
    "nearest_baseline_distance_status",
    "maximum_nearest_baseline_distance_km",
    "latest_baseline_event_date",
    "latest_flickr_candidate_date",
    "latest_reviewed_positive_date",
    "latest_release_ready_date",
    "data_deficient_state",
    "data_deficient_reasons"
  ],
  "properties": {
    "schema_version": {"const": "taxalens-geographic-impact-summary:v1.0.0"},
    "geographic_impact_build_id": {"$ref": "#/$defs/nonEmptyString"},
    "project_id": {"$ref": "#/$defs/nonEmptyString"},
    "run_id": {"$ref": "#/$defs/nonEmptyString"},
    "registry_version": {"$ref": "#/$defs/nonEmptyString"},
    "accepted_taxon_key": {"$ref": "#/$defs/nonEmptyString"},
    "scientific_name": {"$ref": "#/$defs/nonEmptyString"},
    "baseline_snapshot_id": {"$ref": "#/$defs/nonEmptyString"},
    "flickr_snapshot_id": {"$ref": "#/$defs/nonEmptyString"},
    "provider_union_policy_version": {"const": "baseline-provider-union-policy-v1.0.0"},
    "verification_projection_version": {"$ref": "#/$defs/nonEmptyString"},
    "release_policy_version": {"$ref": "#/$defs/nonEmptyString"},
    "country_hierarchy_id": {"$ref": "#/$defs/nonEmptyString"},
    "spatial_resolution": {"type": "integer", "minimum": 0, "maximum": 15},
    "scope_level": {"enum": ["global", "continent", "country", "admin1"]},
    "scope_id": {"$ref": "#/$defs/nonEmptyString"},
    "scope_name": {"$ref": "#/$defs/nonEmptyString"},
    "parent_scope_id": {"$ref": "#/$defs/nullableNonEmptyString"},
    "continent": {"$ref": "#/$defs/nullableContinent"},
    "country_code": {"$ref": "#/$defs/nullableCountryCode"},
    "country": {"$ref": "#/$defs/nullableNonEmptyString"},
    "admin1": {"$ref": "#/$defs/nullableNonEmptyString"},
    "baseline_evidence_status": {"enum": ["available", "unavailable"]},
    "provider_input_row_count": {"$ref": "#/$defs/nullableCount"},
    "baseline_union_count": {"$ref": "#/$defs/nullableCount"},
    "baseline_range_inference_eligible_count": {"$ref": "#/$defs/nullableCount"},
    "baseline_excluded_occurrence_count": {"$ref": "#/$defs/nullableCount"},
    "gbif_only_count": {"$ref": "#/$defs/nullableCount"},
    "inaturalist_origin_through_gbif_count": {"$ref": "#/$defs/nullableCount"},
    "direct_inaturalist_delta_status": {"enum": ["available", "unavailable"]},
    "direct_inaturalist_delta_count": {"$ref": "#/$defs/nullableCount"},
    "duplicates_removed_count": {"$ref": "#/$defs/nullableCount"},
    "unresolved_provider_duplicate_group_count": {"$ref": "#/$defs/nullableCount"},
    "cell_count": {"$ref": "#/$defs/positiveCount"},
    "baseline_occupied_cell_count": {"$ref": "#/$defs/nullableCount"},
    "flickr_candidate_count": {"$ref": "#/$defs/count"},
    "flickr_visually_eligible_count": {"$ref": "#/$defs/count"},
    "reviewed_positive_count": {"$ref": "#/$defs/count"},
    "reviewed_negative_count": {"$ref": "#/$defs/count"},
    "uncertain_count": {"$ref": "#/$defs/count"},
    "pending_count": {"$ref": "#/$defs/count"},
    "media_failure_count": {"$ref": "#/$defs/count"},
    "skipped_count": {"$ref": "#/$defs/count"},
    "release_ready_count": {"$ref": "#/$defs/count"},
    "flickr_occupied_cell_count": {"$ref": "#/$defs/count"},
    "baseline_only_cell_count": {"$ref": "#/$defs/nullableCount"},
    "matched_cell_count": {"$ref": "#/$defs/nullableCount"},
    "candidate_only_cell_count": {"$ref": "#/$defs/nullableCount"},
    "reviewed_additional_cell_count": {"$ref": "#/$defs/nullableCount"},
    "release_ready_additional_cell_count": {"$ref": "#/$defs/nullableCount"},
    "nearest_baseline_distance_status": {"enum": ["available", "unavailable", "not_applicable"]},
    "maximum_nearest_baseline_distance_km": {
      "anyOf": [{"type": "number", "minimum": 0}, {"type": "null"}]
    },
    "latest_baseline_event_date": {"$ref": "#/$defs/nullableDate"},
    "latest_flickr_candidate_date": {"$ref": "#/$defs/nullableDate"},
    "latest_reviewed_positive_date": {"$ref": "#/$defs/nullableDate"},
    "latest_release_ready_date": {"$ref": "#/$defs/nullableDate"},
    "data_deficient_state": {"enum": ["sufficient", "data_deficient", "unavailable"]},
    "data_deficient_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonEmptyString"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"baseline_evidence_status": {"const": "available"}}, "required": ["baseline_evidence_status"]},
      "then": {
        "properties": {
          "provider_input_row_count": {"$ref": "#/$defs/count"},
          "baseline_union_count": {"$ref": "#/$defs/count"},
          "baseline_range_inference_eligible_count": {"$ref": "#/$defs/count"},
          "baseline_excluded_occurrence_count": {"$ref": "#/$defs/count"},
          "gbif_only_count": {"$ref": "#/$defs/count"},
          "inaturalist_origin_through_gbif_count": {"$ref": "#/$defs/count"},
          "duplicates_removed_count": {"$ref": "#/$defs/count"},
          "unresolved_provider_duplicate_group_count": {"$ref": "#/$defs/count"},
          "baseline_occupied_cell_count": {"$ref": "#/$defs/count"},
          "baseline_only_cell_count": {"$ref": "#/$defs/count"},
          "matched_cell_count": {"$ref": "#/$defs/count"},
          "candidate_only_cell_count": {"$ref": "#/$defs/count"},
          "reviewed_additional_cell_count": {"$ref": "#/$defs/count"},
          "release_ready_additional_cell_count": {"$ref": "#/$defs/count"}
        }
      },
      "else": {
        "properties": {
          "provider_input_row_count": {"type": "null"},
          "baseline_union_count": {"type": "null"},
          "baseline_range_inference_eligible_count": {"type": "null"},
          "baseline_excluded_occurrence_count": {"type": "null"},
          "gbif_only_count": {"type": "null"},
          "inaturalist_origin_through_gbif_count": {"type": "null"},
          "direct_inaturalist_delta_status": {"const": "unavailable"},
          "direct_inaturalist_delta_count": {"type": "null"},
          "duplicates_removed_count": {"type": "null"},
          "unresolved_provider_duplicate_group_count": {"type": "null"},
          "baseline_occupied_cell_count": {"type": "null"},
          "baseline_only_cell_count": {"type": "null"},
          "matched_cell_count": {"type": "null"},
          "candidate_only_cell_count": {"type": "null"},
          "reviewed_additional_cell_count": {"type": "null"},
          "release_ready_additional_cell_count": {"type": "null"},
          "nearest_baseline_distance_status": {"const": "unavailable"},
          "maximum_nearest_baseline_distance_km": {"type": "null"},
          "latest_baseline_event_date": {"type": "null"},
          "data_deficient_state": {"const": "unavailable"}
        }
      }
    },
    {
      "if": {"properties": {"direct_inaturalist_delta_status": {"const": "available"}}, "required": ["direct_inaturalist_delta_status"]},
      "then": {"properties": {"direct_inaturalist_delta_count": {"$ref": "#/$defs/count"}}},
      "else": {"properties": {"direct_inaturalist_delta_count": {"type": "null"}}}
    },
    {
      "if": {"properties": {"nearest_baseline_distance_status": {"const": "available"}}, "required": ["nearest_baseline_distance_status"]},
      "then": {"properties": {"maximum_nearest_baseline_distance_km": {"type": "number", "minimum": 0}}},
      "else": {"properties": {"maximum_nearest_baseline_distance_km": {"type": "null"}}}
    },
    {
      "if": {"properties": {"data_deficient_state": {"const": "sufficient"}}, "required": ["data_deficient_state"]},
      "then": {"properties": {"data_deficient_reasons": {"maxItems": 0}}},
      "else": {"properties": {"data_deficient_reasons": {"minItems": 1}}}
    },
    {
      "if": {"properties": {"scope_level": {"const": "global"}}, "required": ["scope_level"]},
      "then": {
        "properties": {
          "scope_id": {"const": "global"},
          "parent_scope_id": {"type": "null"},
          "continent": {"type": "null"},
          "country_code": {"type": "null"},
          "country": {"type": "null"},
          "admin1": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"scope_level": {"const": "continent"}}, "required": ["scope_level"]},
      "then": {
        "properties": {
          "parent_scope_id": {"const": "global"},
          "continent": {"$ref": "#/$defs/continent"},
          "country_code": {"type": "null"},
          "country": {"type": "null"},
          "admin1": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"scope_level": {"const": "country"}}, "required": ["scope_level"]},
      "then": {
        "properties": {
          "parent_scope_id": {"$ref": "#/$defs/nonEmptyString"},
          "continent": {"$ref": "#/$defs/continent"},
          "country_code": {"$ref": "#/$defs/countryCode"},
          "country": {"$ref": "#/$defs/nonEmptyString"},
          "admin1": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"scope_level": {"const": "admin1"}}, "required": ["scope_level"]},
      "then": {
        "properties": {
          "parent_scope_id": {"$ref": "#/$defs/nonEmptyString"},
          "continent": {"$ref": "#/$defs/continent"},
          "country_code": {"$ref": "#/$defs/countryCode"},
          "country": {"$ref": "#/$defs/nonEmptyString"},
          "admin1": {"$ref": "#/$defs/nonEmptyString"}
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "nullableNonEmptyString": {"anyOf": [{"$ref": "#/$defs/nonEmptyString"}, {"type": "null"}]},
    "count": {"type": "integer", "minimum": 0},
    "positiveCount": {"type": "integer", "minimum": 1},
    "nullableCount": {"anyOf": [{"$ref": "#/$defs/count"}, {"type": "null"}]},
    "continent": {"enum": ["Africa", "Antarctica", "Asia", "Europe", "North America", "Oceania", "South America"]},
    "nullableContinent": {"anyOf": [{"$ref": "#/$defs/continent"}, {"type": "null"}]},
    "countryCode": {"type": "string", "pattern": "^[A-Z]{2}$"},
    "nullableCountryCode": {"anyOf": [{"$ref": "#/$defs/countryCode"}, {"type": "null"}]},
    "nullableDate": {"anyOf": [{"type": "string", "format": "date"}, {"type": "null"}]}
  }
}
