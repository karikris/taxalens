{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxalens.local/contracts/country-hierarchy-v1.0.0.schema.json",
  "title": "TaxaLens country hierarchy",
  "description": "A flat, offline geographic navigation hierarchy from the global root through continents, countries, and optional admin1 scopes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "country_hierarchy_id",
    "boundary_dataset_id",
    "boundary_dataset_version",
    "created_at",
    "root_scope_id",
    "nodes"
  ],
  "properties": {
    "schema_version": {"const": "taxalens-country-hierarchy:v1.0.0"},
    "country_hierarchy_id": {"$ref": "#/$defs/nonEmptyString"},
    "boundary_dataset_id": {"$ref": "#/$defs/nonEmptyString"},
    "boundary_dataset_version": {"$ref": "#/$defs/nonEmptyString"},
    "created_at": {"type": "string", "format": "date-time"},
    "root_scope_id": {"const": "global"},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/node"}
    }
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "nullableNonEmptyString": {"anyOf": [{"$ref": "#/$defs/nonEmptyString"}, {"type": "null"}]},
    "continent": {"enum": ["Africa", "Antarctica", "Asia", "Europe", "North America", "Oceania", "South America"]},
    "nullableContinent": {"anyOf": [{"$ref": "#/$defs/continent"}, {"type": "null"}]},
    "countryCode": {"type": "string", "pattern": "^[A-Z]{2}$"},
    "nullableCountryCode": {"anyOf": [{"$ref": "#/$defs/countryCode"}, {"type": "null"}]},
    "bounds": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {"type": "number", "minimum": -180, "maximum": 180},
        {"type": "number", "minimum": -90, "maximum": 90},
        {"type": "number", "minimum": -180, "maximum": 180},
        {"type": "number", "minimum": -90, "maximum": 90}
      ],
      "items": false
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_level",
        "scope_id",
        "scope_name",
        "parent_scope_id",
        "continent",
        "country_code",
        "country",
        "admin1_code",
        "admin1",
        "geometry_feature_id",
        "centroid_latitude",
        "centroid_longitude",
        "bounds",
        "sort_key"
      ],
      "properties": {
        "scope_level": {"enum": ["global", "continent", "country", "admin1"]},
        "scope_id": {"$ref": "#/$defs/nonEmptyString"},
        "scope_name": {"$ref": "#/$defs/nonEmptyString"},
        "parent_scope_id": {"$ref": "#/$defs/nullableNonEmptyString"},
        "continent": {"$ref": "#/$defs/nullableContinent"},
        "country_code": {"$ref": "#/$defs/nullableCountryCode"},
        "country": {"$ref": "#/$defs/nullableNonEmptyString"},
        "admin1_code": {"$ref": "#/$defs/nullableNonEmptyString"},
        "admin1": {"$ref": "#/$defs/nullableNonEmptyString"},
        "geometry_feature_id": {"$ref": "#/$defs/nullableNonEmptyString"},
        "centroid_latitude": {"type": "number", "minimum": -90, "maximum": 90},
        "centroid_longitude": {"type": "number", "minimum": -180, "maximum": 180},
        "bounds": {"$ref": "#/$defs/bounds"},
        "sort_key": {"$ref": "#/$defs/nonEmptyString"}
      },
      "allOf": [
        {
          "if": {"properties": {"scope_level": {"const": "global"}}, "required": ["scope_level"]},
          "then": {
            "properties": {
              "scope_id": {"const": "global"},
              "parent_scope_id": {"type": "null"},
              "continent": {"type": "null"},
              "country_code": {"type": "null"},
              "country": {"type": "null"},
              "admin1_code": {"type": "null"},
              "admin1": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"scope_level": {"const": "continent"}}, "required": ["scope_level"]},
          "then": {
            "properties": {
              "parent_scope_id": {"const": "global"},
              "continent": {"$ref": "#/$defs/continent"},
              "country_code": {"type": "null"},
              "country": {"type": "null"},
              "admin1_code": {"type": "null"},
              "admin1": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"scope_level": {"const": "country"}}, "required": ["scope_level"]},
          "then": {
            "properties": {
              "parent_scope_id": {"$ref": "#/$defs/nonEmptyString"},
              "continent": {"$ref": "#/$defs/continent"},
              "country_code": {"$ref": "#/$defs/countryCode"},
              "country": {"$ref": "#/$defs/nonEmptyString"},
              "admin1_code": {"type": "null"},
              "admin1": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"scope_level": {"const": "admin1"}}, "required": ["scope_level"]},
          "then": {
            "properties": {
              "parent_scope_id": {"$ref": "#/$defs/nonEmptyString"},
              "continent": {"$ref": "#/$defs/continent"},
              "country_code": {"$ref": "#/$defs/countryCode"},
              "country": {"$ref": "#/$defs/nonEmptyString"},
              "admin1_code": {"$ref": "#/$defs/nonEmptyString"},
              "admin1": {"$ref": "#/$defs/nonEmptyString"}
            }
          }
        }
      ]
    }
  }
}
